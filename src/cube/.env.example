CUBEJS_DB_TYPE=bigquery
CUBEJS_DB_BQ_PROJECT_ID=teamster-332318
CUBEJS_DB_NAME=kipptaf_marts
# CUBEJS_DB_BQ_CREDENTIALS omitted — uses ADC locally
CUBEJS_API_SECRET=local-dev-secret
CUBEJS_DEV_MODE=true
CUBEJS_CACHE_AND_QUEUE_DRIVER=memory
CUBEJS_TESSERACT_SQL_PLANNER=true

# SQL API (Postgres wire protocol) — the preferred surface for validating RLS
# locally: checkSqlAuth runs even in dev mode, and it's the prod BI/Superset
# path. See docs/guides/cube.md → "Testing row-level security locally".
CUBEJS_PG_SQL_PORT=15432
CUBEJS_SQL_USER=cube_dev
CUBEJS_SQL_PASSWORD=local-dev-sql
# Whose access to resolve as (dev-only override of the connecting user).
CUBE_SQL_DEV_EMAIL=you@apps.teamschools.org
