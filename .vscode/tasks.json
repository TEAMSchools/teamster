{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup: Post-Build Init",
      "type": "shell",
      "command": "bash .vscode/scripts/setup.sh",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "GCloud: Application Default Login",
      "type": "shell",
      "command": "bash .vscode/scripts/gcloud-application-default-login.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Claude: Login",
      "type": "shell",
      "command": "bash .vscode/scripts/claude-login.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Claude: Install Plugins",
      "type": "shell",
      "command": "bash .vscode/scripts/claude-install-plugins.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Update: Dependencies",
      "type": "shell",
      "command": "bash .vscode/scripts/update-dependencies.sh",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "dbt: Build Init",
      "type": "shell",
      "command": "bash .vscode/scripts/dbt-build-init.sh ${input:dbtProject}",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "dbtProject",
      "type": "pickString",
      "description": "Select a dbt project to build",
      "options": [
        "all",
        "kippcamden",
        "kippmiami",
        "kippnewark",
        "kipppaterson",
        "kipptaf"
      ]
    }
  ]
}
