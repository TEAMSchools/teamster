{
  "diffEditor.experimental.showMoves": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.defaultFormatter": "trunk.io",
  "editor.formatOnSave": true,
  "editor.inlineSuggest.enabled": true,
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "all",
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 88,
  "git.confirmSync": false,
  "git.detectWorktrees": true,
  "git.ignoreRebaseWarning": true,
  "git.repositoryScanMaxDepth": -1,
  "python.analysis.typeCheckingMode": "off",
  "python.createEnvironment.trigger": "off",
  "python.defaultInterpreterPath": "/workspaces/teamster/.venv/bin/python",
  "python.terminal.activateEnvironment": false,
  "python.terminal.useEnvFile": true,
  "python.testing.pytestArgs": ["tests", "--capture=no"],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "testing.showAllMessages": true,
  "trunk.autoInit": false,
  "trunk.enableUpgradePane": false,
  "trunk.showPreexistingIssues": true,
  "trunk.showWhatsNew": false,
  "trunk.trunkPath": "./trunk",
  "yaml.validate": false,
  "files.associations": {
    "*.env": "shellscript",
    "*.toml": "toml"
  },
  "files.exclude": {
    "**/.git": false,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true,
    "**/dbt_packages/": true
  },
  "files.watcherExclude": {
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true,
    "**/dbt_packages/**": true,
    "**/target/**": true
  },
  "[json]": {
    "editor.defaultFormatter": "trunk.io"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "trunk.io"
  },
  "[python]": {
    "editor.defaultFormatter": "trunk.io"
  },
  "terminal.integrated.env.linux": {
    "DAGSTER_HOME": "${workspaceFolder}/.dagster/home",
    "DBT_PROFILES_DIR": "${workspaceFolder}/.dbt",
    "GOOGLE_CLOUD_PROJECT": "teamster-332318",
    "PYTHONDONTWRITEBYTECODE": "1",
    "TRUNK_TELEMETRY": "off",
    "UV_LINK_MODE": "copy",
    "UV_RESOLUTION": "highest"
  },
  "yaml.customTags": [
    "tag:yaml.org,2002:python/name:material.extensions.emoji.twemoji scalar",
    "tag:yaml.org,2002:python/name:material.extensions.emoji.to_svg scalar"
  ],
  "dbtCoreTools.profilesDir": ".dbt",
  "dbtCoreTools.deferManifestPath": {
    "kipptaf": "src/dbt/kipptaf/target/prod",
    "kippnewark": "src/dbt/kippnewark/target/prod",
    "kippcamden": "src/dbt/kippcamden/target/prod",
    "kippmiami": "src/dbt/kippmiami/target/prod",
    "kipppaterson": "src/dbt/kipppaterson/target/prod"
  }
}
