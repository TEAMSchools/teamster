{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(python -m pytest tests/ -x -q)",
      "Read(//home/vscode/.claude/plugins/cache/dagster/**)",
      "WebFetch(domain:docs.dagster.io)",
      "WebFetch(domain:github.com)",
      "Bash(git add:*)"
    ]
  },
  "enabledPlugins": {
    "dagster-expert@dagster": true,
    "dagster-integrations@dagster": true,
    "dignified-python@dagster": true,
    "dbt@dbt-agent-marketplace": true
  },
  "extraKnownMarketplaces": {
    "dagster-skills": {
      "source": {
        "source": "github",
        "repo": "dagster-io/skills"
      }
    },
    "dbt-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dbt-labs/dbt-agent-skills"
      }
    }
  }
}
