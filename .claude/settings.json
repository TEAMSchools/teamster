{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(python -m pytest tests/ -x -q)",
      "Read(/workspaces/teamster/src/**)",
      "Read(~/.claude/plugins/**)",
      "WebFetch(domain:docs.dagster.io)",
      "WebFetch(domain:github.com)"
    ]
  },
  "enabledPlugins": {
    "dignified-python@dagster": true,
    "dbt@dbt-agent-marketplace": true,
    "dagster-expert@dagster": true
  },
  "extraKnownMarketplaces": {
    "dagster-skills": {
      "source": {
        "source": "github",
        "repo": "dagster-io/skills"
      }
    },
    "dbt-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dbt-labs/dbt-agent-skills"
      }
    }
  }
}
