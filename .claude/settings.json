{
  "extraKnownMarketplaces": {
    "dagster-skills": {
      "source": {
        "source": "github",
        "repo": "dagster-io/skills"
      }
    },
    "dbt-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dbt-labs/dbt-agent-skills"
      }
    }
  },
  "enabledPlugins": {
    "dignified-python@dagster": true,
    "dbt@dbt-agent-marketplace": true,
    "dagster-expert@dagster": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(git add:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(trunk check:*)",
      "Bash(trunk fmt:*)",
      "Bash(uv tool list:*)",
      "Read(/workspaces/teamster/**)",
      "Read(~/.claude/plugins/**)",
      "WebFetch(domain:docs.dagster.io)",
      "WebFetch(domain:github.com)",
      "mcp__bigquery__*",
      "mcp__dagster__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sed -i -E '/(_SECRET|_TOKEN|_PASSWORD|_CREDENTIAL|PRIVATE_KEY|SERVICE_ACCOUNT|OP_SERVICE)/Id' /home/vscode/.claude/shell-snapshots/snapshot-bash-*.sh 2>/dev/null; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sed -i -E '/(_SECRET|_TOKEN|_PASSWORD|_CREDENTIAL|PRIVATE_KEY|SERVICE_ACCOUNT|OP_SERVICE)/Id' /home/vscode/.claude/shell-snapshots/snapshot-bash-*.sh 2>/dev/null; true",
            "statusMessage": "Sanitizing shell snapshots..."
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash|Grep|Glob|NotebookEdit|WebFetch|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-sensitive.sh",
            "statusMessage": "Checking if path is safe to access..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Edit|Grep|NotebookEdit|WebFetch|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-output.sh",
            "statusMessage": "Scanning output for secret leakage..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "trunk fmt {changed_files}",
            "statusMessage": "Auto-formatting with Trunk",
            "async": true
          }
        ]
      }
    ]
  }
}
